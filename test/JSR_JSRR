0x1021 // 0x3000: ADD R0, R0, #1 (R0 = 1)
0x4804 // 0x3001: JSR #4         (JSR: PC:0x3002 + 4 = 0x3006 へジャンプ)
0xE205 // 0x3002: LEA R1, #5     (JSRR用: PC:0x3003 + 5 = 0x3008 を R1 にセット)
0x4040 // 0x3003: JSRR R1        (JSRR: R1(0x3008) へジャンプ)
0x1021 // 0x3004: [最終復帰先] ADD R0, R0, #1 (R0 = 3 + 1 = 4 になる)
0xF025 // 0x3005: TRAP 0x25      (HALT: プログラム終了)
0x1021 // 0x3006: [Sub1 (JSR用)]  ADD R0, R0, #1 (R0 = 1 + 1 = 2)
0xC1C0 // 0x3007: [Sub1 (JSR用)]  RET            (0x3002 へ復帰)
0x1021 // 0x3008: [Sub2 (JSRR用)] ADD R0, R0, #1 (R0 = 2 + 1 = 3)
0xC1C0 // 0x3009: [Sub2 (JSRR用)] RET            (0x3004 へ復帰)
